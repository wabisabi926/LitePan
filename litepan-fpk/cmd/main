#!/bin/bash

APP_DIR=$(cd "$(dirname "$0")/.." && pwd)
SERVER_DIR="${APP_DIR}/app/server"
PID_FILE="${APP_DIR}/litepan.pid"
LOG_FILE="${APP_DIR}/litepan.log"
DATA_DIR="${TRIM_APPDEST_VOL}/1000/apps/litepan/data"
LOG_DIR="${TRIM_APPDEST_VOL}/1000/apps/litepan/log"
STRM_DIR="${TRIM_APPDEST_VOL}/1000/apps/litepan/strm"
PLUGINS_DIR="${TRIM_APPDEST_VOL}/1000/apps/litepan/plugins"

PORT=${LITEPAN_PORT:-5211}
HOST=${LITEPAN_HOST:-0.0.0.0}

PYTHON_BIN="python3"

if [ -d "${SERVER_DIR}/.venv/bin" ]; then
    PYTHON_BIN="${SERVER_DIR}/.venv/bin/python3"
elif [ -d "${SERVER_DIR}/.venv/Scripts" ]; then
    PYTHON_BIN="${SERVER_DIR}/.venv/Scripts/python.exe"
fi

ensure_directories() {
    mkdir -p "${DATA_DIR}" "${LOG_DIR}" "${STRM_DIR}" "${PLUGINS_DIR}"
}

log_message() {
    local level="$1"
    local message="$2"
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] [${level}] ${message}" | tee -a "${LOG_FILE}"
}

start() {
    ensure_directories
    
    if [ -f "${PID_FILE}" ]; then
        local pid=$(cat "${PID_FILE}")
        if kill -0 "${pid}" 2>/dev/null; then
            log_message "INFO" "LitePan 已在运行中 (PID: ${pid})"
            exit 0
        fi
        rm -f "${PID_FILE}"
    fi

    log_message "INFO" "正在启动 LitePan 服务..."
    log_message "INFO" "服务器目录: ${SERVER_DIR}"
    log_message "INFO" "数据目录: ${DATA_DIR}"
    log_message "INFO" "日志目录: ${LOG_DIR}"
    log_message "INFO" "监听地址: ${HOST}:${PORT}"

    cd "${SERVER_DIR}" || exit 1

    export LITEPAN_PORT="${PORT}"
    export LITEPAN_HOST="${HOST}"
    export LITEPAN_DATA_DIR="${DATA_DIR}"
    export LITEPAN_DATABASE_PATH="${DATA_DIR}/litepan.db"
    export LITEPAN_LOG_DIR="${LOG_DIR}"
    export LITEPAN_STRM_DIR="${STRM_DIR}"
    export LITEPAN_PLUGINS_DIR="${PLUGINS_DIR}"

    nohup "${PYTHON_BIN}" main.py > "${LOG_FILE}" 2>&1 &
    local pid=$!
    echo "${pid}" > "${PID_FILE}"

    sleep 2

    if kill -0 "${pid}" 2>/dev/null; then
        log_message "INFO" "LitePan 服务启动成功 (PID: ${pid})"
        exit 0
    else
        log_message "ERROR" "LitePan 服务启动失败，请查看日志: ${LOG_FILE}"
        rm -f "${PID_FILE}"
        exit 1
    fi
}

stop() {
    if [ ! -f "${PID_FILE}" ]; then
        log_message "INFO" "LitePan 服务未运行"
        exit 0
    fi

    local pid=$(cat "${PID_FILE}")
    
    if ! kill -0 "${pid}" 2>/dev/null; then
        log_message "INFO" "LitePan 服务进程已不存在，清理 PID 文件"
        rm -f "${PID_FILE}"
        exit 0
    fi

    log_message "INFO" "正在停止 LitePan 服务 (PID: ${pid})"
    
    kill "${pid}" 2>/dev/null
    sleep 3

    if kill -0 "${pid}" 2>/dev/null; then
        log_message "WARN" "优雅停止失败，强制终止进程"
        kill -9 "${pid}" 2>/dev/null
        sleep 1
    fi

    rm -f "${PID_FILE}"
    log_message "INFO" "LitePan 服务已停止"
    exit 0
}

status() {
    if [ ! -f "${PID_FILE}" ]; then
        echo "stopped"
        exit 0
    fi

    local pid=$(cat "${PID_FILE}")
    if kill -0 "${pid}" 2>/dev/null; then
        echo "running"
        exit 0
    else
        rm -f "${PID_FILE}"
        echo "stopped"
        exit 0
    fi
}

case "$1" in
    start)
        start
        ;;
    stop)
        stop
        ;;
    status)
        status
        ;;
    *)
        echo "Usage: $0 {start|stop|status}"
        exit 1
        ;;
esac
